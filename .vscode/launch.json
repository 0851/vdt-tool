// A launch configuration that launches the extension inside a new window
{
    "version": "0.1.0",
    "configurations": [
        {
            "name": "client",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": ["--extensionDevelopmentPath=${workspaceRoot}"],
            "sourceMaps": true,
            "outFiles": ["${workspaceRoot}/out/**/*.js"],
            "preLaunchTask": "watch"
        },
        {
            "name": "serve",
            "type": "node",
            "request": "attach",
            "port": 6888,
            "protocol": "inspector",
            "sourceMaps": true,
            "outFiles": ["${workspaceRoot}/serve/out/**/*.js"],
            "preLaunchTask": "watch:serve"
        }
    ]
}

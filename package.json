{
    "name": "vdt-tool",
    "version": "1.0.0",
    "displayName": "vdt扩展工具",
    "description": "vdt 文件的VS Code 插件",
    "main": "index.js",
    "icon": "asset/vdt.png",
    "scripts": {},
    "repository": {
        "type": "git",
        "url": "git+https://github.com/0851/vdt-tool.git"
    },
    "keywords": [
        "vdt",
        "templates",
        "vscode",
        "intact"
    ],
    "author": "wangjianliang",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/0851/vdt-tool/issues"
    },
    "homepage": "https://github.com/0851/vdt-tool#readme",
    "publisher": "wangjianliang",
    "engines": {
        "vscode": "^1.19.0"
    },
    "categories": [
        "Languages",
        "Other",
        "Snippets"
    ],
    "activationEvents": [
        "onLanguage:vdt"
    ],
    "contributes": {
        "languages": [
            {
                "id": "vdt",
                "aliases": [
                    "vdt",
                    "vdt-template"
                ],
                "extensions": [
                    ".vdt"
                ],
                "configuration": "./language/vdt.language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "vdt",
                "scopeName": "source.vdt",
                "path": "./syntaxes/vdt.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "vdt",
                "path": "./snippets/vdt.snippets.json"
            }
        ]
    },
    "devDependencies": {
        "vscode": "^1.1.10"
    }
}

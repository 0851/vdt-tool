{
    "name": "vdt-tool",
    "version": "1.0.0",
    "displayName": "vdt扩展工具",
    "description": "vdt 文件的VS Code 插件",
    "main": "./out/index.js",
    "icon": "asset/vdt.png",
    "scripts": {
        "compile": "tsc -p .",
        "package": "vsce package",
        "precommit": "lint-staged",
        "prepush": "npm run test:serve",
        "minor": "vsce publish minor",
        "major": "vsce publish major",
        "patch": "vsce publish patch",
        "lint": "tslint -p tslint.json",
        "test:serve": "cd serve && npm run compile && npm test",
        "test": "npm run lint && npm run test:serve",
        "vscode:prepublish": "npm run compile"
    },
    "lint-staged": {
        "*.ts": ["tslint --fix", "git add"]
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/0851/vdt-tool.git"
    },
    "keywords": ["vdt", "templates", "vscode", "intact"],
    "author": "wangjianliang",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/0851/vdt-tool/issues"
    },
    "homepage": "https://github.com/0851/vdt-tool#readme",
    "publisher": "wangjianliang",
    "engines": {
        "vscode": "^1.19.0"
    },
    "categories": ["Languages", "Other", "Snippets"],
    "activationEvents": ["onLanguage:vdt"],
    "contributes": {
        "languages": [
            {
                "id": "vdt",
                "aliases": ["vdt", "vdt-template"],
                "extensions": [".vdt"],
                "configuration": "./language/vdt.language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "vdt",
                "scopeName": "source.vdt",
                "path": "./syntaxes/vdt.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "vdt",
                "path": "./snippets/vdt.snippets.json"
            }
        ]
    },
    "devDependencies": {
        "@types/node": "^9.3.0",
        "husky": "^0.14.3",
        "lint-staged": "^6.1.0",
        "tslint": "^5.9.1",
        "typescript": "^2.6.2",
        "vsce": "^1.36.1",
        "vscode": "^1.1.10"
    },
    "dependencies": {
        "vscode-languageclient": "^3.5.0"
    }
}
